apiVersion: v1
kind: Secret
metadata:
  name: knowledge-secrets
  namespace: smap
  labels:
    app.kubernetes.io/name: knowledge
    app.kubernetes.io/part-of: smap
type: Opaque
stringData:
  # PostgreSQL (external VM)
  POSTGRES_USER: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"

  # Redis
  REDIS_PASSWORD: "CHANGE_ME"

  # Qdrant
  QDRANT_API_KEY: "CHANGE_ME"

  # MinIO
  MINIO_ACCESS_KEY: "CHANGE_ME"
  MINIO_SECRET_KEY: "CHANGE_ME"

  # AI Services
  VOYAGE_API_KEY: "CHANGE_ME"
  GEMINI_API_KEY: "CHANGE_ME"

  # JWT Configuration
  JWT_SECRET_KEY: "CHANGE_ME_min_32_chars"

  # Encrypter Configuration
  ENCRYPTER_KEY: "CHANGE_ME_exactly_32_chars______"

  # Internal Configuration
  INTERNAL_INTERNAL_KEY: "CHANGE_ME"

  # Discord Configuration (optional)
  DISCORD_WEBHOOK_URL: ""
