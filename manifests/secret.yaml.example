apiVersion: v1
kind: Secret
metadata:
  name: knowledge-secrets
  namespace: smap
  labels:
    app.kubernetes.io/name: knowledge
    app.kubernetes.io/part-of: smap
type: Opaque
stringData:
  # PostgreSQL Credentials
  POSTGRES_USER: "CHANGE_ME"
  POSTGRES_PASSWORD: "CHANGE_ME"

  # Redis Password
  REDIS_PASSWORD: "CHANGE_ME"

  # Qdrant API Key (optional - set to empty string if not required)
  QDRANT_API_KEY: ""

  # MinIO Credentials
  MINIO_ACCESS_KEY: "CHANGE_ME"
  MINIO_SECRET_KEY: "CHANGE_ME"

  # AI Services API Keys
  VOYAGE_API_KEY: "CHANGE_ME"
  GEMINI_API_KEY: "CHANGE_ME"

  # JWT Secret (minimum 32 characters)
  JWT_SECRET_KEY: "CHANGE_ME_minimum_32_characters_required_for_security"
  JWT_SECRET: "CHANGE_ME_minimum_32_characters_required_for_security"

  # Encrypter Key (minimum 32 characters)
  ENCRYPTER_KEY: "CHANGE_ME_minimum_32_characters!!"
  ENCRYPT_KEY: "CHANGE_ME_minimum_32_characters!!"

  # Internal API Key
  INTERNAL_INTERNAL_KEY: "CHANGE_ME"
  INTERNAL_KEY: "CHANGE_ME"

  # Discord Webhook URL (optional)
  DISCORD_WEBHOOK_URL: "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"
